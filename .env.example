# ============================================================
# TRADER AI — Variables de entorno
# Copiar a .env y completar los valores reales
# Generar JWT_SECRET_KEY: python -c "import secrets; print(secrets.token_hex(32))"
# ============================================================

# ── Ejecución ────────────────────────────────────────────────
# NUNCA cambiar a live sin validación completa en papel (FASE G)
EXECUTION_MODE=paper
TRADING_ENABLED=false

# ── Base de datos ────────────────────────────────────────────
# Debe coincidir con docker/docker-compose.yml
DATABASE_URL=postgresql+asyncpg://trader:trader@localhost:5432/trader_ai
REDIS_URL=redis://localhost:6379

# ── Autenticación JWT ────────────────────────────────────────
# Generar con: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=PEGAR_AQUI_EL_VALOR_GENERADO
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ── Binance (FASE A — Testnet para empezar) ──────────────────
# Obtener en: https://testnet.binance.vision/ → My API Keys
BINANCE_API_KEY=tu_key_testnet
BINANCE_SECRET_KEY=tu_secret_testnet
BINANCE_TESTNET=true

# ── MetaTrader 5 / IC Markets (FASE E) ──────────────────────
# Dejar MT5_LOGIN=0 hasta completar FASE E
# Servidor demo IC Markets: ICMarketsSC-Demo04
MT5_SERVER=ICMarketsSC-Demo04
MT5_LOGIN=0
MT5_PASSWORD=

# ── Telegram — alertas (FASE A opcional) ────────────────────
# Crear bot en @BotFather → obtener token
# Obtener CHAT_ID: enviar mensaje al bot y consultar /getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Límites de riesgo (no modificar sin revisión) ────────────
MAX_RISK_PER_TRADE_PCT=0.01
MAX_PORTFOLIO_RISK_PCT=0.10
DAILY_LOSS_LIMIT_PCT=0.05
MAX_CONSECUTIVE_LOSSES=5
MAX_DRAWDOWN_PCT=0.15

# ── Portfolio ────────────────────────────────────────────────
PORTFOLIO_BASE_CURRENCY=USD

# ── Proveedores opcionales (no requeridos en FASE A) ─────────
# BYBIT_API_KEY=
# BYBIT_SECRET_KEY=
# OANDA_API_KEY=
# OANDA_ACCOUNT_ID=
# OANDA_ENVIRONMENT=practice
# ALPHA_VANTAGE_API_KEY=
