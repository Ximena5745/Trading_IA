# TRADER AI — Environment variables example
# Copy to .env and fill in your values. Never commit .env to git.

# ── Execution mode ──────────────────────────────────────────────────────────
# paper  = simulated trading, no real orders (safe default)
# live   = real money trading (requires valid API keys + TRADING_ENABLED=true)
EXECUTION_MODE=paper

# ── Safety switch ───────────────────────────────────────────────────────────
# Must be explicitly set to "true" to enable live order submission
TRADING_ENABLED=false

# ── Authentication ──────────────────────────────────────────────────────────
# Minimum 32 characters. Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-to-a-random-secret-at-least-32-chars

# ════════════════════════════════════════════════════════════════════════════
# CRYPTO EXCHANGES
# ════════════════════════════════════════════════════════════════════════════

# ── Binance (crypto) ─────────────────────────────────────────────────────────
# Testnet keys: https://testnet.binance.vision/
BINANCE_API_KEY=
BINANCE_SECRET_KEY=
BINANCE_TESTNET=true

# ── Bybit (crypto) ───────────────────────────────────────────────────────────
BYBIT_API_KEY=
BYBIT_SECRET_KEY=

# ════════════════════════════════════════════════════════════════════════════
# FOREX / INDICES / COMMODITIES
# OANDA covers all three asset classes with a single account.
# ════════════════════════════════════════════════════════════════════════════

# ── OANDA (forex + indices + commodities) ────────────────────────────────────
# Sign up (free practice account): https://www.oanda.com/us-en/trading/
# Practice API token: https://www.oanda.com/us-en/trading/api/ → "Manage API Access"
OANDA_API_KEY=
OANDA_ACCOUNT_ID=
# "practice" for demo account (safe default), "live" for real money
OANDA_ENVIRONMENT=practice

# Instruments available via OANDA:
#   Forex:       EUR_USD, GBP_USD, USD_JPY, USD_CHF, AUD_USD, USD_CAD
#   Indices:     SPX500_USD, NAS100_USD, US30_USD, DE30_EUR, UK100_GBP
#   Commodities: XAU_USD (gold), XAG_USD (silver), WTICO_USD (WTI oil),
#                BCO_USD (Brent oil), NATGAS_USD, WHEAT_USD

# ════════════════════════════════════════════════════════════════════════════
# MARKET DATA PROVIDERS (optional — enhance data quality)
# ════════════════════════════════════════════════════════════════════════════

# ── Alpha Vantage ─────────────────────────────────────────────────────────────
# Free tier: 25 requests/day. Paid: unlimited.
# Get key: https://www.alphavantage.co/support/#api-key
# Covers: forex, stocks, ETFs, commodities, crypto
ALPHA_VANTAGE_API_KEY=

# ════════════════════════════════════════════════════════════════════════════
# INFRASTRUCTURE
# ════════════════════════════════════════════════════════════════════════════

# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://trader:trader@localhost:5432/trader_ai

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Telegram alerts (optional) ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ════════════════════════════════════════════════════════════════════════════
# RISK LIMITS
# ════════════════════════════════════════════════════════════════════════════
MAX_RISK_PER_TRADE_PCT=0.01
MAX_PORTFOLIO_RISK_PCT=0.10
DAILY_LOSS_LIMIT_PCT=0.05
MAX_CONSECUTIVE_LOSSES=5
MAX_DRAWDOWN_PCT=0.15
