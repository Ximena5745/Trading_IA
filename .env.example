# ============================================================
# TRADER AI — Environment Variables
# Copy to .env and fill in your values
# NEVER commit .env to version control
# ============================================================

# --- Execution ---
# CRITICAL: Keep as 'paper' until fully validated
EXECUTION_MODE=paper
TRADING_ENABLED=false

# --- Binance ---
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_SECRET_KEY=your_binance_secret_key_here
# Use testnet for development (true = testnet, false = mainnet)
BINANCE_TESTNET=true

# --- Database (TimescaleDB) ---
DATABASE_URL=postgresql+asyncpg://trader:password@localhost:5432/trader_ai
DB_PASSWORD=password

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Authentication ---
# Generate a strong random key: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-to-a-secure-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# --- Risk Limits ---
MAX_RISK_PER_TRADE_PCT=0.01
MAX_PORTFOLIO_RISK_PCT=0.10
DAILY_LOSS_LIMIT_PCT=0.05
MAX_CONSECUTIVE_LOSSES=5
MAX_DRAWDOWN_PCT=0.15

# --- Features ---
FEATURE_VERSION=v1
DEFAULT_TIMEFRAME=1h

# --- Telegram Alerts (optional) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Grafana ---
GRAFANA_PASSWORD=admin
